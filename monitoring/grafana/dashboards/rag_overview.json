{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "App Status",
      "type": "stat",
      "targets": [{ "expr": "up{job=\"rag_app\"}", "legendFormat": "Status", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Total Chunks in Vector Store",
      "type": "stat",
      "targets": [{ "expr": "rag_vector_store_total_chunks", "legendFormat": "Chunks", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Query Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(rag_query_requests_total[5m])", "legendFormat": "req/s", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "P95 Query Latency",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "P95", "refId": "A" }]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.05 }, { "color": "red", "value": 0.1 }] } } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Query Error Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(rag_query_requests_total{status=\"failure\"}[5m]) / rate(rag_query_requests_total[5m])", "legendFormat": "Error Rate", "refId": "A" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Query Performance",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Query Latency Percentiles",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "P90", "refId": "B" },
        { "expr": "histogram_quantile(0.95, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "P95", "refId": "C" },
        { "expr": "histogram_quantile(0.99, rate(rag_query_duration_seconds_bucket[5m]))", "legendFormat": "P99", "refId": "D" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Query Throughput (Success vs Failure)",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(rag_query_requests_total{status=\"success\"}[1m])", "legendFormat": "Success", "refId": "A" },
        { "expr": "rate(rag_query_requests_total{status=\"failure\"}[1m])", "legendFormat": "Failure", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 102,
      "title": "LLM & Embeddings",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "LLM Call Latency",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(rag_llm_duration_seconds_bucket[5m]))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(rag_llm_duration_seconds_bucket[5m]))", "legendFormat": "P95", "refId": "B" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "LLM Token Usage",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(rag_llm_input_tokens_total[5m])", "legendFormat": "Input tokens/s", "refId": "A" },
        { "expr": "rate(rag_llm_output_tokens_total[5m])", "legendFormat": "Output tokens/s", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 103,
      "title": "Document Ingestion",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 30,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Documents Uploaded",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(rag_documents_uploaded_total{status=\"success\"}[5m])", "legendFormat": "Success", "refId": "A" },
        { "expr": "rate(rag_documents_uploaded_total{status=\"failure\"}[5m])", "legendFormat": "Failure", "refId": "B" },
        { "expr": "rag_document_processing_in_progress", "legendFormat": "In Progress", "refId": "C" }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 31,
      "options": { "legend": { "calcs": ["mean", "p95"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Document Processing Duration",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(rag_document_processing_duration_seconds_bucket[15m]))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(rag_document_processing_duration_seconds_bucket[15m]))", "legendFormat": "P95", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 104,
      "title": "Cache",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.3 }, { "color": "green", "value": 0.7 }] } } },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 33 },
      "id": 40,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Cache Hit Rate",
      "type": "stat",
      "targets": [{ "expr": "rate(rag_cache_hits_total[5m]) / (rate(rag_cache_hits_total[5m]) + rate(rag_cache_misses_total[5m]))", "legendFormat": "Hit Rate", "refId": "A" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["rag", "gcp"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "RAG on GCP - Overview",
  "uid": "rag-overview-001",
  "version": 1
}
