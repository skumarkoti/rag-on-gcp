# ── Copy this file to .env and fill in your values ──────────────────────────
# cp .env.example .env

# ── Required: GCP Configuration ─────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET_NAME=your-rag-bucket-name

# ── Required: Vertex AI ──────────────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
EMBEDDING_MODEL=text-embedding-004
LLM_MODEL=gemini-1.5-pro-002

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=local          # local | staging | production
LOG_LEVEL=INFO
DEBUG=false
PORT=8080

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/tmp/chroma_data
CHROMA_COLLECTION_NAME=rag_documents
CHROMA_SYNC_TO_GCS=true    # Set false for local dev

# ── PDF Processing ───────────────────────────────────────────────────────────
PDF_CHUNK_SIZE=1000
PDF_CHUNK_OVERLAP=200
PDF_MAX_FILE_SIZE_MB=500
PDF_PROCESSING_BATCH_SIZE=50

# ── RAG Parameters ───────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
RAG_MAX_CONTEXT_TOKENS=12000

# ── Caching ───────────────────────────────────────────────────────────────────
REDIS_URL=                  # Leave empty to disable caching
                            # Example: redis://localhost:6379
CACHE_TTL_SECONDS=3600

# ── LLM Settings ─────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192

# ── Monitoring ───────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PATH=/metrics
